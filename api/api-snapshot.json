	"packageName": "@anvilkit/plugin-export-html",
	"readme": [
		{
			"kind": "text",
			"text": "# @anvilkit/plugin-export-html\n\nHTML export plugin for Anvilkit Studio. "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/plugin-export-html`"
		},
		{
			"kind": "text",
			"text": "\nregisters the first real Phase 3 export format, turning "
		},
		{
			"kind": "code",
			"text": "`PageIR`"
		},
		{
			"kind": "text",
			"text": "\ndocuments into standalone HTML with emitted CSS, optional asset\ninlining, and a matching Studio header action for interactive export\nflows.\n\n> **Alpha status (0.1.x).** The package surface is implemented and\n> tested, but the emitted HTML/CSS contract may still evolve before\n> "
		},
		{
			"kind": "code",
			"text": "`0.1.0`"
		},
		{
			"kind": "text",
			"text": ".\n\n## Install\n\n"
		},
		{
			"kind": "code",
			"text": "```bash\npnpm add @anvilkit/plugin-export-html @anvilkit/core react react-dom @puckeditor/core\n```"
		},
		{
			"kind": "text",
			"text": "\n\n## Quickstart\n\n"
		},
		{
			"kind": "code",
			"text": "```ts\nimport { Studio } from \"@anvilkit/core\";\nimport { puckDataToIR } from \"@anvilkit/ir\";\nimport { createHtmlExportPlugin } from \"@anvilkit/plugin-export-html\";\nimport { puckConfig } from \"./puck-config\";\n\nconst htmlExport = createHtmlExportPlugin({\n  title: \"Marketing page\",\n  lang: \"en\",\n  inlineAssetThresholdBytes: 32_768,\n  // Optional — when supplied, the \"Download HTML\" header action runs\n  // the export end-to-end and emits `anvilkit:export:ready` with the\n  // resulting payload. Otherwise it emits `anvilkit:export:request`\n  // for the host to handle.\n  buildIR: (ctx) => puckDataToIR(ctx.getData(), puckConfig),\n});\n\n<Studio puckConfig={puckConfig} plugins={[htmlExport]} />;\n```"
		},
		{
			"kind": "text",
			"text": "\n\nOptions passed to "
		},
		{
			"kind": "code",
			"text": "`createHtmlExportPlugin()`"
		},
		{
			"kind": "text",
			"text": " are used as defaults for\nevery export run; host calls to "
		},
		{
			"kind": "code",
			"text": "`exportAs(\"html\", { … })`"
		},
		{
			"kind": "text",
			"text": " shallow-merge\non top.\n\n## Public API\n\n| Export | Purpose |\n| ------ | ------- |\n| "
		},
		{
			"kind": "code",
			"text": "`createHtmlExportPlugin`"
		},
		{
			"kind": "text",
			"text": " | Register the HTML export format and its header action with "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/core`"
		},
		{
			"kind": "text",
			"text": ". Options passed here become run-time defaults. |\n| "
		},
		{
			"kind": "code",
			"text": "`htmlFormat`"
		},
		{
			"kind": "text",
			"text": " | Direct "
		},
		{
			"kind": "code",
			"text": "`ExportFormatDefinition`"
		},
		{
			"kind": "text",
			"text": " for headless export pipelines and tests. |\n| "
		},
		{
			"kind": "code",
			"text": "`createExportHtmlHeaderAction`"
		},
		{
			"kind": "text",
			"text": " | Build a header action bound to a configured format and options. Used internally by "
		},
		{
			"kind": "code",
			"text": "`createHtmlExportPlugin`"
		},
		{
			"kind": "text",
			"text": ". |\n| "
		},
		{
			"kind": "code",
			"text": "`exportHtmlHeaderAction`"
		},
		{
			"kind": "text",
			"text": " | Default unbound header action; emits an "
		},
		{
			"kind": "code",
			"text": "`anvilkit:export:request`"
		},
		{
			"kind": "text",
			"text": " event for hosts to handle. |\n| "
		},
		{
			"kind": "code",
			"text": "`HtmlExportOptions`"
		},
		{
			"kind": "text",
