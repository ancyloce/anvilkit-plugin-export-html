			"text": "`react-dom`"
		},
		{
			"kind": "text",
			"text": " | "
		},
		{
			"kind": "code",
			"text": "`^18.2.0`"
		},
		{
			"kind": "text",
			"text": " |\n| "
		},
		{
			"kind": "code",
			"text": "`@puckeditor/core`"
		},
		{
			"kind": "text",
