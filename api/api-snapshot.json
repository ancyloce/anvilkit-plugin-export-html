	"packageName": "@anvilkit/plugin-export-html",
	"readme": [
		{
			"kind": "text",
			"text": "# @anvilkit/plugin-export-html\n\nHTML export plugin for Anvilkit Studio. "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/plugin-export-html`"
		},
		{
			"kind": "text",
			"text": "\nregisters the first real Phase 3 export format, turning "
		},
		{
			"kind": "code",
			"text": "`PageIR`"
		},
		{
			"kind": "text",
			"text": "\ndocuments into standalone HTML with emitted CSS, optional asset\ninlining, and a matching Studio header action for interactive export\nflows.\n\n> **Alpha status (0.1.x).** The package surface is implemented and\n> tested, but the emitted HTML/CSS contract may still evolve before\n> "
		},
		{
			"kind": "code",
			"text": "`0.1.0`"
		},
		{
			"kind": "text",
			"text": ".\n\n## Install\n\n"
		},
		{
			"kind": "code",
			"text": "```bash\npnpm add @anvilkit/plugin-export-html @anvilkit/core react react-dom @puckeditor/core\n```"
		},
		{
			"kind": "text",
			"text": "\n\n## Quickstart\n\n"
		},
		{
			"kind": "code",
			"text": "```ts\nimport { Studio } from \"@anvilkit/core\";\nimport { createHtmlExportPlugin } from \"@anvilkit/plugin-export-html\";\nimport { puckConfig } from \"./puck-config\";\n\nconst htmlExport = createHtmlExportPlugin({\n  title: \"Marketing page\",\n  inlineStyles: true,\n  inlineAssetThresholdBytes: 32_768,\n});\n\n<Studio puckConfig={puckConfig} plugins={[htmlExport]} />;\n```"
		},
		{
			"kind": "text",
			"text": "\n\n## Public API\n\n| Export | Purpose |\n| ------ | ------- |\n| "
		},
		{
			"kind": "code",
			"text": "`createHtmlExportPlugin`"
		},
		{
			"kind": "text",
			"text": " | Register the HTML export format and its header action with "
		},
		{
			"kind": "code",
			"text": "`@anvilkit/core`"
		},
		{
			"kind": "text",
			"text": ". |\n| "
		},
		{
			"kind": "code",
			"text": "`htmlFormat`"
		},
		{
			"kind": "text",
			"text": " | Direct "
		},
		{
			"kind": "code",
			"text": "`ExportFormatDefinition`"
		},
		{
			"kind": "text",
			"text": " for headless export pipelines and tests. |\n| "
		},
		{
			"kind": "code",
			"text": "`exportHtmlHeaderAction`"
		},
		{
			"kind": "text",
			"text": " | Studio header action that exposes the HTML export affordance in host UIs. |\n| "
		},
		{
			"kind": "code",
			"text": "`HtmlExportOptions`"
		},
		{
			"kind": "text",
			"text": " | Configure document title, asset inlining, inline styles, and custom asset fetchers. |\n| "
		},
		{
			"kind": "code",
			"text": "`FetchAssetFn`"
		},
		{
			"kind": "text",
			"text": " | Host-supplied async asset loader used when inlining external assets. |\n\n## Phase 3 references\n\nSee the [Phase 3 plan]("
		},
		{
			"kind": "relative-link",
			"text": "../../../docs/plans/phase-3-export-ai-pipeline-plan.md",
			"target": 2
		},
		{
			"kind": "text",
			"text": ")\n("
		},
		{
			"kind": "code",
			"text": "`M4 — @anvilkit/plugin-export-html`"
		},
		{
			"kind": "text",
			"text": ") and the\n[architecture package catalog]("
		},
		{
			"kind": "relative-link",
			"text": "../../../docs/ai-context/anvilkit-architecture.md",
			"target": 3
		},
		{
			"kind": "text",
			"text": ")\n("
		},
		{
			"kind": "code",
			"text": "`§7 — @anvilkit/plugins [Stubs Exist]`"
		},
		{
			"kind": "text",
			"text": ") for the export-plugin role and\nPhase 3 dependency layering.\n\n## Peer dependencies\n\n| Package | Version |\n| ------- | ------- |\n| "
		},
		{
			"kind": "code",
			"text": "`react`"
		},
		{
			"kind": "text",
			"text": " | "
		},
