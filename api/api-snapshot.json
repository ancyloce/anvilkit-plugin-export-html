	"packageName": "@anvilkit/plugin-export-html",
	"readme": [
		{
			"kind": "text",
			"text": "# @anvilkit/plugin-export-html\n\nHTML export format package for Anvilkit Studio.\n\n## Status\n\n"
		},
		{
			"kind": "code",
			"text": "`0.1.0-alpha.0`"
		},
		{
			"kind": "text",
			"text": " scaffold only. This package currently registers a stub HTML export format and returns a placeholder HTML document.\n\n## Quickstart\n\n"
		},
		{
			"kind": "code",
			"text": "```ts\nimport { createHtmlExportPlugin } from \"@anvilkit/plugin-export-html\";\n\nconst htmlPlugin = createHtmlExportPlugin();\n```"
		},
		{
			"kind": "text",
			"text": "\n\nUse the returned plugin in your Studio plugin list. It contributes a single export format with id "
		},
		{
			"kind": "code",
			"text": "`\"html\"`"
		},
		{
			"kind": "text",
			"text": ".\n\n## Roadmap\n\nReal HTML emitters and option threading land in "
		},
		{
			"kind": "code",
			"text": "`phase3-010`"
		},
		{
			"kind": "text",
			"text": "."
		}
	],
